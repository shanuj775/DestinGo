rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserRecord() {
      return signedIn() && request.auth.uid == resource.data.userId;
    }

    match /destinations/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /places/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /events/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /hosts/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /savedTrips/{docId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if ownsUserRecord();
    }

    match /bookings/{docId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if ownsUserRecord();
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }
  }
}
